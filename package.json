{
  "name": "chatbot",
  "version": "1.0.0",
  "description": "WhatsApp Flows backend (Meta Cloud API)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --testEnvironment node",
    "db:migrate": "prisma migrate dev",
