// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id              String          @id @default(uuid()) @db.Uuid
  nombre          String          @db.VarChar(100)
  slug            String          @unique @db.VarChar(50)
  apiKey          String          @unique @db.VarChar(64) @map("api_key")
  activo          Boolean         @default(true)
  plan            String          @default("free") @db.VarChar(20)
  logoUrl         String?         @db.VarChar(500) @map("logo_url")
  createdAt       DateTime        @default(now()) @map("created_at")
  users           User[]
  solicitudes     Solicitud[]
  slaPolicies     SlaPolicy[]
  solicitudAssignmentRules SolicitudAssignmentRule[]
  solicitudTemplates SolicitudTemplate[]
  webhookConfigs  WebhookConfig[]
  eventosFlujo    EventoFlujo[]
  agentes         Agente[]
  configuraciones Configuracion[]
  flows                Flow[]
  mensajes             Mensaje[]
  conversationContexts ConversationContext[]
  waSendQueue          WaSendQueue[]
  wabaRescueLogs       WabaRescueLog[]
  agendaEvents         AgendaEvent[]
  agendaEventLogs      AgendaEventLog[]
  eventLogs            EventLog[]
  deadLetterEntries    DeadLetterQueue[]
  flowSessions         FlowSession[]
  flowVersions         FlowVersion[]
  flowExecutions       FlowExecution[]
  integrations         Integration[]
  flowVariables        FlowVariable[]
  conversations        Conversation[]
  calendars            Calendar[]
  appointments         Appointment[]
  wabaImportLogs       WabaImportLog[]
  deals                Deal[]
  crmTasks             CrmTask[]
  agentePuestos        AgentePuesto[]

  @@map("tenants")
}

model EventSchema {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  version   String   @db.VarChar(20)
  schema    Json
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, version])
  @@map("event_schemas")
}

model EventLog {
  id             Int       @id @default(autoincrement())
  tenantId       String    @map("tenant_id") @db.Uuid
  eventId        String    @unique @map("event_id") @db.VarChar(80)
  eventVersion   String    @default("1.0") @map("event_version") @db.VarChar(20)
  channel        String    @db.VarChar(40)
  source         String    @db.VarChar(60)
  eventType      String    @map("event_type") @db.VarChar(80)
  direction      String    @default("inbound") @db.VarChar(20)
  idempotencyKey String    @map("idempotency_key") @db.VarChar(191)
  status         String    @default("ingested") @db.VarChar(20)
  occurredAt     DateTime  @map("occurred_at")
  ingestedAt     DateTime  @default(now()) @map("ingested_at")
  processedAt    DateTime? @map("processed_at")
  payload        Json
  metadata       Json?
  rawEvent       Json?     @map("raw_event")
  lastError      String?   @map("last_error") @db.Text
  attempts       Int       @default(0)
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deadLetters    DeadLetterQueue[]

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, ingestedAt])
  @@index([tenantId, eventType, ingestedAt])
  @@map("event_logs")
}

model DeadLetterQueue {
  id          Int       @id @default(autoincrement())
  tenantId    String    @map("tenant_id") @db.Uuid
  eventLogId  Int?      @map("event_log_id")
  reason      String    @db.VarChar(255)
  error       Json?
  payload     Json?
  status      String    @default("pending") @db.VarChar(20)
  attempts    Int       @default(0)
  nextRetryAt DateTime? @map("next_retry_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eventLog    EventLog? @relation(fields: [eventLogId], references: [id], onDelete: SetNull)

  @@index([status, nextRetryAt])
  @@index([tenantId, createdAt])
  @@map("dead_letter_queue")
}

model User {
  id              Int           @id @default(autoincrement())
  tenantId        String        @map("tenant_id") @db.Uuid
  phone           String?       @db.VarChar(20)
  // CRM profile
  nombre          String?       @db.VarChar(120)
  email           String?       @db.VarChar(150)
  empresa         String?       @db.VarChar(120)
  cargo           String?       @db.VarChar(100)
  canalOrigen     String?       @default("whatsapp") @map("canal_origen") @db.VarChar(40)
  etiquetas       String[]      @default([])
  notas           String?       @db.Text
  customFields    Json?         @default("{}") @map("custom_fields")
  ultimoContacto  DateTime?     @map("ultimo_contacto")
  leadScore       Int           @default(0) @map("lead_score") @db.SmallInt
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @default(now()) @updatedAt @map("updated_at")
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  solicitudes         Solicitud[]
  eventosFlujo        EventoFlujo[]
  mensajes            Mensaje[]
  conversationContexts ConversationContext[]
  deals               Deal[]
  tasks               CrmTask[]

  @@unique([tenantId, phone])
  @@index([tenantId, nombre])
  @@index([tenantId, email])
  @@map("users")
}

model Deal {
  id              Int       @id @default(autoincrement())
  tenantId        String    @map("tenant_id") @db.Uuid
  userId          Int?      @map("user_id")
  agenteId        Int?      @map("agente_id")
  titulo          String    @db.VarChar(200)
  etapa           String    @default("nuevo") @db.VarChar(60)
  valor           Decimal?  @db.Decimal(14, 2)
  moneda          String?   @default("ARS") @db.VarChar(10)
  probabilidad    Int?      @default(0) @db.SmallInt
  cierreEsperado  DateTime? @map("cierre_esperado") @db.Date
  notas           String?   @db.Text
  cerradoEn       DateTime? @map("cerrado_en")
  perdidoRazon    String?   @map("perdido_razon") @db.VarChar(255)
  customFields    Json?     @default("{}") @map("custom_fields")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  agente          Agente?   @relation(fields: [agenteId], references: [id], onDelete: SetNull)
  tasks           CrmTask[]

  @@index([tenantId, etapa])
  @@index([tenantId, userId])
  @@map("deals")
}

model CrmTask {
  id            Int       @id @default(autoincrement())
  tenantId      String    @map("tenant_id") @db.Uuid
  userId        Int?      @map("user_id")
  dealId        Int?      @map("deal_id")
  agenteId      Int?      @map("agente_id")
  titulo        String    @db.VarChar(200)
  descripcion   String?   @db.Text
  tipo          String    @default("seguimiento") @db.VarChar(40)
  estado        String    @default("pendiente") @db.VarChar(40)
  venceEn       DateTime? @map("vence_en")
  completadoEn  DateTime? @map("completado_en")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  deal          Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  agente        Agente?   @relation(fields: [agenteId], references: [id], onDelete: SetNull)

  @@index([tenantId, estado])
  @@index([tenantId, agenteId])
  @@map("crm_tasks")
}

model Solicitud {
  id               Int      @id @default(autoincrement())
  tenantId         String   @map("tenant_id") @db.Uuid
  userId           Int?     @map("user_id")
  agenteId         Int?     @map("agente_id")
  flowId           Int?     @map("flow_id")
  conversationId   String?  @map("conversation_id") @db.Uuid
  slaId            Int?     @map("sla_id")
  origin           String   @default("manual") @db.VarChar(20)
  titulo           String?  @db.VarChar(160)
  prioridad        String?  @db.VarChar(20)
  flowNodeRef      String?  @map("flow_node_ref") @db.VarChar(120)
  nombre           String?  @db.VarChar(100)
  telefonoContacto String?  @db.VarChar(20)   @map("telefono_contacto")
  horario          String?  @db.VarChar(20)
  estado           String?  @db.VarChar(50)
  variablesJson    Json?    @map("variables_json")
  attachmentsJson  Json     @default("[]") @map("attachments_json")
  internalComments Json     @default("[]") @map("internal_comments_json")
  slaCreatedAt     DateTime? @map("sla_created_at")
  slaCompletedAt   DateTime? @map("sla_completed_at")
  escalatedAt      DateTime? @map("escalated_at")
  escalationLevel  Int      @default(0) @map("escalation_level")
  tags             Json     @default("[]") @map("tags")
  customFields     Json     @default("{}") @map("custom_fields")
  resolutionNotes  String?  @map("resolution_notes") @db.Text
  customerNotes    String?  @map("customer_notes") @db.Text
  followUpDate     DateTime? @map("follow_up_date")
  channelSource    String   @default("manual") @db.VarChar(50) @map("channel_source")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")
  completedAt      DateTime? @map("completed_at")
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  user             User?    @relation(fields: [userId], references: [id])
  agente           Agente?  @relation(fields: [agenteId], references: [id])
  flow             Flow?    @relation(fields: [flowId], references: [id], onDelete: SetNull)
  conversation     Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  slaPolicy        SlaPolicy? @relation(fields: [slaId], references: [id], onDelete: SetNull)
  comments         SolicitudComment[]
  history          SolicitudHistory[]

  @@index([tenantId, estado, createdAt])
  @@index([tenantId, conversationId])
  @@index([tenantId, flowId])
  @@index([tenantId, slaId])
  @@index([tenantId, escalationLevel])
  @@index([tenantId, escalatedAt])
  @@map("solicitudes")
}

// ── Enterprise: SLA & Solicitudes ─────────────────────────────────────────────

/// SLA Policy: Define response and resolution times for solicitudes
model SlaPolicy {
  id                    Int      @id @default(autoincrement())
  tenantId              String   @map("tenant_id") @db.Uuid
  nombre                String   @db.VarChar(150)
  descripcion           String?  @db.Text
  responseTimeMinutes   Int      @default(60) @map("response_time_minutes")
  resolutionTimeMinutes Int      @default(1440) @map("resolution_time_minutes")
  escalationRules       Json     @default("[]") @map("escalation_rules")
  active                Boolean  @default(true)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  solicitudes           Solicitud[]
  templates             SolicitudTemplate[]

  @@unique([tenantId, nombre])
  @@index([tenantId, active])
  @@map("sla_policies")
}

/// Solicitud History: Immutable audit trail of all changes
model SolicitudHistory {
  id          Int       @id @default(autoincrement())
  solicitudId Int       @map("solicitud_id")
  field       String    @db.VarChar(100)
  oldValue    String?   @map("old_value") @db.Text
  newValue    String?   @map("new_value") @db.Text
  userId      Int?      @map("user_id")
  timestamp   DateTime  @default(now())
  solicitud   Solicitud @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  user        AdminUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([solicitudId])
  @@index([timestamp])
  @@map("solicitud_history")
}

/// Solicitud Comments: Collaboration between team members and customers
model SolicitudComment {
  id          Int       @id @default(autoincrement())
  solicitudId Int       @map("solicitud_id")
  userId      Int?      @map("user_id")
  content     String    @db.Text
  /// "internal" | "customer" | "both"
  visibility  String    @default("internal") @db.VarChar(20)
  attachments Json      @default("[]")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  solicitud   Solicitud @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  user        AdminUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([solicitudId])
  @@index([createdAt])
  @@map("solicitud_comments")
}

/// Solicitud Assignment Rules: Auto-route solicitudes based on criteria
model SolicitudAssignmentRule {
  id            Int       @id @default(autoincrement())
  tenantId      String    @map("tenant_id") @db.Uuid
  criterios     Json      @default("{}")
  targetAgenteId Int?     @map("target_agente_id")
  roundRobin    Boolean   @default(false) @map("round_robin")
  enabled       Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  targetAgente  Agente?   @relation(fields: [targetAgenteId], references: [id], onDelete: SetNull)

  @@index([tenantId, enabled])
  @@map("solicitud_assignment_rules")
}

/// Solicitud Templates: Pre-configured templates for quick solicitud creation
model SolicitudTemplate {
  id                Int       @id @default(autoincrement())
  tenantId          String    @map("tenant_id") @db.Uuid
  nombre            String    @db.VarChar(150)
  prioridad         String    @default("media") @db.VarChar(20)
  slaId             Int?      @map("sla_id")
  tags              Json      @default("[]")
  defaultVariables  Json      @default("{}") @map("default_variables")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slaPolicy         SlaPolicy? @relation(fields: [slaId], references: [id], onDelete: SetNull)

  @@unique([tenantId, nombre])
  @@index([tenantId])
  @@map("solicitud_templates")
}

/// Webhook Configurations: Send events to external systems
model WebhookConfig {
  id               Int       @id @default(autoincrement())
  tenantId         String    @map("tenant_id") @db.Uuid
  event            String    @db.VarChar(100)
  url              String    @db.VarChar(500)
  active           Boolean   @default(true)
  lastTriggeredAt  DateTime? @map("last_triggered_at")
  failureCount     Int       @default(0) @map("failure_count")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, event, url])
  @@index([tenantId])
  @@index([event])
  @@map("webhook_configs")
}

model EventoFlujo {
  id        Int      @id @default(autoincrement())
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    Int?     @map("user_id")
  screen    String?  @db.VarChar(50)
  data      Json?
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@map("eventos_flujo")
}

model Agente {
  id          Int         @id @default(autoincrement())
  tenantId    String      @map("tenant_id") @db.Uuid
  nombre      String      @db.VarChar(100)
  email       String      @db.VarChar(150)
  whatsapp    String?     @db.VarChar(30)
  puestoId    Int?        @map("puesto_id")
  calendarLink String?    @map("calendar_link") @db.VarChar(500)
  estado      String      @default("activo") @db.VarChar(20)
  lastSeenAt  DateTime?   @map("last_seen_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  puesto      AgentePuesto? @relation(fields: [puestoId], references: [id], onDelete: SetNull)
  solicitudes Solicitud[]
  agendaAssignments AgendaEventAssignment[]
  deals             Deal[]
  crmTasks          CrmTask[]
  calendars         Calendar[]
  assignmentRules   SolicitudAssignmentRule[]

  @@index([tenantId, puestoId])
  @@map("agentes")
}

model AgentePuesto {
  id        Int      @id @default(autoincrement())
  tenantId  String   @map("tenant_id") @db.Uuid
  nombre    String   @db.VarChar(100)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentes   Agente[]

  @@unique([tenantId, nombre])
  @@index([tenantId, activo])
  @@map("agente_puestos")
}

model Configuracion {
  id        Int      @id @default(autoincrement())
  tenantId  String   @map("tenant_id") @db.Uuid
  clave     String   @db.VarChar(100)
  valor     Json
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, clave])
  @@map("configuraciones")
}

// ── RBAC ──────────────────────────────────────────────────────────────────────

model AdminUser {
  id              Int            @id @default(autoincrement())
  tenantId        String?        @map("tenant_id") @db.Uuid
  email           String         @unique @db.VarChar(150)
  passwordHash    String         @map("password_hash") @db.VarChar(255)
  nombre          String         @db.VarChar(100)
  superAdmin      Boolean        @default(false) @map("super_admin")
  failedAttempts  Int            @default(0) @map("failed_attempts")
  lockedUntil     DateTime?      @map("locked_until")
  createdAt       DateTime       @default(now()) @map("created_at")
  roles           AdminUserRole[]
  auditLogs       AuditLog[]
  refreshTokens   RefreshToken[]
  wabaRescueLogs  WabaRescueLog[]
  agendaEventsCreated AgendaEvent[]       @relation("AgendaEventCreatedBy")
  agendaEventLogs     AgendaEventLog[]
  flowVersionsCreated FlowVersion[]       @relation("FlowVersionCreatedBy")
  solicitudHistory    SolicitudHistory[]
  solicitudComments   SolicitudComment[]

  @@map("admin_users")
}

model Role {
  id          Int            @id @default(autoincrement())
  tenantId    String?        @map("tenant_id") @db.Uuid
  nombre      String         @db.VarChar(100)
  createdAt   DateTime       @default(now()) @map("created_at")
  permisos    RolePermiso[]
  users       AdminUserRole[]

  @@map("roles")
}

model Permiso {
  id     Int           @id @default(autoincrement())
  clave  String        @unique @db.VarChar(100)
  roles  RolePermiso[]

  @@map("permisos")
}

model RolePermiso {
  roleId    Int    @map("role_id")
  permisoId Int    @map("permiso_id")
  role      Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permiso   Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@id([roleId, permisoId])
  @@map("role_permisos")
}

model AdminUserRole {
  adminUserId Int       @map("admin_user_id")
  roleId      Int       @map("role_id")
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([adminUserId, roleId])
  @@map("admin_user_roles")
}

// ── Auditoría ─────────────────────────────────────────────────────────────────

model RefreshToken {
  id          Int       @id @default(autoincrement())
  adminUserId Int       @map("admin_user_id")
  tokenHash   String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt   DateTime  @map("expires_at")
  revoked     Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@map("refresh_tokens")
}

model AuditLog {
  id          Int        @id @default(autoincrement())
  tenantId    String?    @map("tenant_id") @db.Uuid
  adminUserId Int?       @map("admin_user_id")
  accion      String     @db.VarChar(100)
  entidad     String     @db.VarChar(100)
  entidadId   String?    @map("entidad_id") @db.VarChar(100)
  ip          String?    @db.VarChar(45)
  userAgent   String?    @map("user_agent") @db.VarChar(500)
  metadata    Json?
  createdAt   DateTime   @default(now()) @map("created_at")
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id])

  @@index([tenantId])
  @@index([accion])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── Flujos dinámicos ──────────────────────────────────────────────────────────

model Flow {
  id           Int        @id @default(autoincrement())
  tenantId     String     @map("tenant_id") @db.Uuid
  nombre       String     @db.VarChar(100)
  version      Int        @default(1)
  activo       Boolean    @default(true)
  /// Snapshot del JSON Meta exportado (version 7.1) guardado en cada save
  metaJson     Json?      @map("meta_json")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  nodes        FlowNode[]
  edges        FlowEdge[]
  sessions     FlowSession[]
  agendaEvents AgendaEvent[]
  flowVersions FlowVersion[]
  executions   FlowExecution[]
  variables    FlowVariable[]
  conversations Conversation[]
  solicitudes  Solicitud[]

  @@map("flows")
}

model FlowSession {
  id                  Int      @id @default(autoincrement())
  tenantId            String   @map("tenant_id") @db.Uuid
  flowId              Int      @map("flow_id")
  sessionKey          String   @map("session_key") @db.VarChar(120)
  status              String   @default("active") @db.VarChar(20)
  currentScreenId     String?  @map("current_screen_id") @db.VarChar(120)
  stateJson           Json     @default("{}") @map("state_json")
  businessContextJson Json?    @map("business_context_json")
  auditEventsJson     Json     @default("[]") @map("audit_events_json")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flow                Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@unique([tenantId, flowId, sessionKey])
  @@index([tenantId, updatedAt])
  @@index([flowId, status])
  @@map("flow_sessions")
}

// ── Agenda ───────────────────────────────────────────────────────────────────

model AgendaEvent {
  id                     Int      @id @default(autoincrement())
  tenantId               String   @map("tenant_id") @db.Uuid
  createdByAdminUserId   Int?     @map("created_by_admin_user_id")
  flowId                 Int?     @map("flow_id")
  titulo                 String   @db.VarChar(160)
  descripcion            String?  @db.Text
  tipo                   String   @db.VarChar(30)
  color                  String   @default("#60A5FA") @db.VarChar(20)
  estado                 String   @default("pendiente") @db.VarChar(30)
  startAt                DateTime @map("start_at")
  endAt                  DateTime @map("end_at")
  reminderMinutes        Int?     @map("reminder_minutes")
  triggerWebhookOnStart  Boolean  @default(false) @map("trigger_webhook_on_start")
  webhookUrl             String?  @map("webhook_url") @db.VarChar(500)
  webhookMethod          String?  @map("webhook_method") @db.VarChar(10)
  webhookHeaders         Json?    @map("webhook_headers")
  webhookPayload         Json?    @map("webhook_payload")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator                AdminUser? @relation("AgendaEventCreatedBy", fields: [createdByAdminUserId], references: [id], onDelete: SetNull)
  flow                   Flow?    @relation(fields: [flowId], references: [id], onDelete: SetNull)
  assignments            AgendaEventAssignment[]
  logs                   AgendaEventLog[]

  @@index([tenantId, startAt])
  @@index([tenantId, estado, startAt])
  @@index([tenantId, tipo, startAt])
  @@map("agenda_events")
}

model AgendaEventAssignment {
  eventId   Int   @map("event_id")
  agenteId  Int   @map("agente_id")
  createdAt DateTime @default(now()) @map("created_at")
  event     AgendaEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  agente    Agente      @relation(fields: [agenteId], references: [id], onDelete: Cascade)

  @@id([eventId, agenteId])
  @@index([agenteId])
  @@map("agenda_event_assignments")
}

model AgendaEventLog {
  id            Int      @id @default(autoincrement())
  tenantId      String   @map("tenant_id") @db.Uuid
  eventId       Int      @map("event_id")
  adminUserId   Int?     @map("admin_user_id")
  accion        String   @db.VarChar(80)
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event         AgendaEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  adminUser     AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([eventId, createdAt])
  @@map("agenda_event_logs")
}

model FlowNode {
  id       Int      @id @default(autoincrement())
  flowId   Int      @map("flow_id")
  type     String   @db.VarChar(50)
  content  Json
  posX     Float    @default(0) @map("pos_x")
  posY     Float    @default(0) @map("pos_y")
  flow     Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  edgesOut FlowEdge[] @relation("SourceNode")
  edgesIn  FlowEdge[] @relation("TargetNode")

  @@map("flow_nodes")
}

model FlowEdge {
  id           Int      @id @default(autoincrement())
  flowId       Int      @map("flow_id")
  sourceNodeId Int      @map("source_node_id")
  targetNodeId Int      @map("target_node_id")
  condition    String?  @db.VarChar(255)
  flow         Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  sourceNode   FlowNode @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode   FlowNode @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@map("flow_edges")
}

