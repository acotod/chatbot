// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id              String          @id @default(uuid()) @db.Uuid
  nombre          String          @db.VarChar(100)
  slug            String          @unique @db.VarChar(50)
  apiKey          String          @unique @db.VarChar(64) @map("api_key")
  activo          Boolean         @default(true)
  plan            String          @default("free") @db.VarChar(20)
  createdAt       DateTime        @default(now()) @map("created_at")
  users           User[]
  solicitudes     Solicitud[]
  eventosFlujo    EventoFlujo[]
  agentes         Agente[]
  configuraciones Configuracion[]

  @@map("tenants")
}

model User {
  id           Int           @id @default(autoincrement())
  tenantId     String        @map("tenant_id") @db.Uuid
  phone        String?       @db.VarChar(20)
  createdAt    DateTime      @default(now()) @map("created_at")
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  solicitudes  Solicitud[]
  eventosFlujo EventoFlujo[]

  @@unique([tenantId, phone])
  @@map("users")
}

model Solicitud {
  id               Int      @id @default(autoincrement())
  tenantId         String   @map("tenant_id") @db.Uuid
  userId           Int?     @map("user_id")
  agenteId         Int?     @map("agente_id")
  nombre           String?  @db.VarChar(100)
  telefonoContacto String?  @db.VarChar(20)   @map("telefono_contacto")
  horario          String?  @db.VarChar(20)
  estado           String?  @db.VarChar(50)
  createdAt        DateTime @default(now()) @map("created_at")
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  user             User?    @relation(fields: [userId], references: [id])
  agente           Agente?  @relation(fields: [agenteId], references: [id])

  @@map("solicitudes")
}

model EventoFlujo {
  id        Int      @id @default(autoincrement())
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    Int?     @map("user_id")
  screen    String?  @db.VarChar(50)
  data      Json?
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@map("eventos_flujo")
}

model Agente {
  id          Int         @id @default(autoincrement())
  tenantId    String      @map("tenant_id") @db.Uuid
  nombre      String      @db.VarChar(100)
  email       String      @db.VarChar(150)
  estado      String      @default("activo") @db.VarChar(20)
  createdAt   DateTime    @default(now()) @map("created_at")
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  solicitudes Solicitud[]

  @@map("agentes")
}

model Configuracion {
  id        Int      @id @default(autoincrement())
  tenantId  String   @map("tenant_id") @db.Uuid
  clave     String   @db.VarChar(100)
  valor     Json
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, clave])
  @@map("configuraciones")
}
