// ── Enterprise: Versionado, Ejecución, Integraciones ─────────────────────────

/// Snapshot inmutable de la definición de un flujo en un momento dado.
/// La columna `definition` es JSONB y contiene la estructura completa de nodos,
/// variables e integraciones — el motor de ejecución trabaja SOLO con este JSON.
model FlowVersion {
  id                   Int       @id @default(autoincrement())
  tenantId             String    @map("tenant_id") @db.Uuid
  flowId               Int       @map("flow_id")
  versionNumber        Int       @map("version_number")
  /// Full JSONB: { entry_point, nodes:[{id,type,config,next,integrationRef?}], variables:{}, metadata:{} }
  definition           Json
  changelog            String?   @db.Text
  published            Boolean   @default(false)
  publishedAt          DateTime? @map("published_at")
  createdByAdminUserId Int?      @map("created_by_admin_user_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flow                 Flow      @relation(fields: [flowId], references: [id], onDelete: Cascade)
  creator              AdminUser? @relation("FlowVersionCreatedBy", fields: [createdByAdminUserId], references: [id], onDelete: SetNull)
  executions           FlowExecution[]
  conversations        Conversation[]

  /// "draft" | "valid" | "invalid" | "exported"
  wabaValidationStatus String    @default("draft") @map("waba_validation_status") @db.VarChar(20)
  wabaValidatedAt      DateTime? @map("waba_validated_at")
  wabaValidationErrors Json?     @map("waba_validation_errors")

  @@unique([flowId, versionNumber])
  @@index([tenantId, flowId, published])
  @@index([tenantId, createdAt])
  @@map("flow_versions")
}

/// Registro de ejecución de un flujo por usuario/sesión.
/// Reemplaza ConversationContext para flujos versionados (JSONB-based).
/// `variables` y `context` son JSONB para máxima flexibilidad.
model FlowExecution {
  id              Int       @id @default(autoincrement())
  tenantId        String    @map("tenant_id") @db.Uuid
  flowId          Int       @map("flow_id")
  flowVersionId   Int?      @map("flow_version_id")
  /// Identificador de sesión: phone number, socket id, etc.
  sessionKey      String    @map("session_key") @db.VarChar(120)
  /// "active" | "completed" | "error" | "abandoned"
  status          String    @default("active") @db.VarChar(20)
  /// ID del nodo actual dentro del JSON (ej: "node_1")
  currentNodeRef  String?   @map("current_node_ref") @db.VarChar(120)
  /// Variables de sesión dinámicas (capturadas durante el flujo)
  variables       Json      @default("{}")
  /// Contexto extra: intent, metadata de canal, etc.
  context         Json      @default("{}")
  errorCount      Int       @default(0) @map("error_count")
  startedAt       DateTime  @default(now()) @map("started_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  completedAt     DateTime? @map("completed_at")
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flow            Flow      @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowVersion     FlowVersion? @relation(fields: [flowVersionId], references: [id], onDelete: SetNull)
  logs            ExecutionLog[]

  @@unique([tenantId, flowId, sessionKey])
  @@index([tenantId, status, updatedAt])
  @@index([flowId, status])
  @@index([tenantId, updatedAt])
  @@map("flow_executions")
}

/// Log atómico por nodo ejecutado dentro de un FlowExecution.
/// Permite auditoría completa paso a paso y debugging de flujos.
model ExecutionLog {
  id           Int      @id @default(autoincrement())
  executionId  Int      @map("execution_id")
  tenantId     String   @map("tenant_id") @db.Uuid
  /// Referencia al nodo en el JSON (ej: "node_3")
  nodeRef      String   @map("node_ref") @db.VarChar(120)
  nodeType     String   @map("node_type") @db.VarChar(50)
  /// Input recibido en este paso
  input        Json?
  /// Output generado (texto, respuesta de API, etc.)
  output       Json?
  durationMs   Int?     @map("duration_ms")
  /// "ok" | "error" | "skipped"
  status       String   @default("ok") @db.VarChar(20)
  errorMessage String?  @map("error_message") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  execution    FlowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, createdAt])
  @@index([tenantId, createdAt])
  @@map("execution_logs")
}

/// Configuración de integraciones dinámicas (webhooks, REST APIs, OAuth2).
/// El motor de ejecución resuelve nodos tipo "action" contra esta tabla —
/// sin hardcode de endpoints, headers ni lógica de autenticación.
model Integration {
  id        Int      @id @default(autoincrement())
  tenantId  String   @map("tenant_id") @db.Uuid
  nombre    String   @db.VarChar(100)
  /// "webhook" | "rest_api" | "oauth2" | "apikey"
  tipo      String   @db.VarChar(30)
  /// JSONB: { endpoint, method, headers, auth:{type,key?,token?,oauth_config?},
  ///          body_mapping:{}, response_mapping:{}, timeout_ms, retry_count }
  config    Json
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, nombre])
  @@index([tenantId, activo])
  @@map("integrations")
}

/// Definición de variables de flujo: globales (flowId=null) o por flujo.
/// Permite al motor resolver plantillas {{variable}} sin hardcode.
model FlowVariable {
  id           Int      @id @default(autoincrement())
  tenantId     String   @map("tenant_id") @db.Uuid
  /// null = variable global del tenant
  flowId       Int?     @map("flow_id")
  nombre       String   @db.VarChar(100)
  /// "string" | "number" | "boolean" | "object" | "array"
  tipo         String   @default("string") @db.VarChar(20)
  /// Valor por defecto serializado como JSONB
  valorDefault Json?    @map("valor_default")
  descripcion  String?  @db.VarChar(255)
  /// "global" | "flow" | "session"
  scope        String   @default("flow") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flow         Flow?    @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@unique([tenantId, flowId, nombre])
  @@index([tenantId, scope])
  @@map("flow_variables")
}

// ── Conversations (Event Sourcing) ────────────────────────────────────────────

/// Una sesión conversacional completa de un usuario con un flujo.
/// `context` JSONB: snapshot del estado actual (nodo, variables) para sesiones activas.
model Conversation {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  /// Identificador del usuario final (phone number u otro canal)
  userKey         String    @map("user_key") @db.VarChar(120)
  flowId          Int       @map("flow_id")
  flowVersionId   Int?      @map("flow_version_id")
  /// "active" | "completed" | "abandoned" | "error"
  status          String    @default("active") @db.VarChar(20)
  /// JSONB snapshot: { current_node: "node_5", variables: { name: "Juan" } }
  context         Json      @default("{}")
  startedAt       DateTime  @default(now()) @map("started_at")
  endedAt         DateTime? @map("ended_at")
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flow            Flow      @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowVersion     FlowVersion? @relation(fields: [flowVersionId], references: [id], onDelete: SetNull)
  events          ConversationEvent[]
  appointments    Appointment[]
  solicitudes     Solicitud[]
  mensajes        Mensaje[]

  @@unique([tenantId, userKey, flowId, startedAt])
  @@index([tenantId, status, startedAt])
  @@index([tenantId, userKey])
  @@index([flowId, status])
  @@map("conversations")
}

/// Evento atómico dentro de una conversación — nunca se sobreescribe.
/// Cada paso del flujo genera uno o más eventos (inmutable, append-only).
///
/// payload JSONB por tipo:
///   flow_start      → { flow_id, flow_version, entry_point }
///   message_sent    → { node_id, node_type, text, buttons?, sections? }
///   user_input      → { node_id, raw_input, matched_button_id? }
///   menu_selection  → { node_id, selected_id, selected_title }
///   condition_eval  → { node_id, expression, resolved, result: true|false, next_node }
///   api_call        → { node_id, integration_ref, endpoint, method, body_mapping }
///   api_response    → { node_id, integration_ref, status_code, response_vars, duration_ms }
///   llm_call        → { node_id, model, prompt_tokens, completion_tokens }
///   variable_set    → { node_id, variable, value }
///   flow_end        → { node_id, final_variables }
///   flow_handoff    → { node_id, reason }
///   flow_error      → { node_id, error_message }
model ConversationEvent {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  nodeRef        String?  @map("node_ref") @db.VarChar(120)
  /// See event types above
  eventType      String   @map("event_type") @db.VarChar(50)
  payload        Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([tenantId, eventType, createdAt])
  @@index([tenantId, createdAt])
  @@map("conversation_events")
}

// ── Calendar Domain ───────────────────────────────────────────────────────────

/// Represents a bookable calendar belonging to a tenant.
/// config JSONB: { working_hours, slot_duration_min, buffer_min, advance_days,
///                provider: "internal"|"google"|"outlook",
///                provider_credentials: {}, sync: true }
model Calendar {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  agenteId    Int?      @map("agente_id")
  name        String    @db.VarChar(200)
  timezone    String    @default("America/Mexico_City") @db.VarChar(60)
  activo      Boolean   @default(true)
  /// Full calendar configuration (see JSDoc above)
  config      Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agente      Agente?   @relation(fields: [agenteId], references: [id], onDelete: SetNull)
  slots       CalendarSlot[]
  appointments Appointment[]

  @@index([tenantId, activo])
  @@index([tenantId, agenteId])
  @@map("calendars")
}

/// Pre-computed or blocked time slots for a calendar.
/// Row per slot. "available" slots are consumed on booking → status = "booked".
/// Concurrency is handled via SELECT FOR UPDATE on status='available'.
model CalendarSlot {
  id         String    @id @default(uuid()) @db.Uuid
  calendarId String    @map("calendar_id") @db.Uuid
  startTime  DateTime  @map("start_time") @db.Timestamptz
  endTime    DateTime  @map("end_time") @db.Timestamptz
  /// "available" | "booked" | "blocked"
  status     String    @default("available") @db.VarChar(20)
  /// Reference to the appointment that booked this slot (if booked)
  appointmentId String? @map("appointment_id") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  calendar   Calendar  @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@index([calendarId, status, startTime])
  @@index([calendarId, startTime, endTime])
  @@map("calendar_slots")
}

/// A booked appointment within a calendar, tied to a conversation.
/// metadata JSONB: { user_name, notes, reminder_sent, external_event_id, ... }
model Appointment {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  conversationId String?   @map("conversation_id") @db.Uuid
  /// Phone number or other user identifier
  userKey        String    @map("user_key") @db.VarChar(120)
  calendarId     String    @map("calendar_id") @db.Uuid
  startTime      DateTime  @map("start_time") @db.Timestamptz
  endTime        DateTime  @map("end_time") @db.Timestamptz
  /// "scheduled" | "cancelled" | "completed" | "no_show" | "rescheduled"
  status         String    @default("scheduled") @db.VarChar(20)
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  calendar       Calendar  @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, startTime])
  @@index([calendarId, startTime])
  @@index([tenantId, userKey, startTime])
  @@index([conversationId])
  @@map("appointments")
}

// ── WABA Flow Import ──────────────────────────────────────────────────────────

/// Audit trail for every WABA JSON import operation.
model WabaImportLog {
  id                Int       @id @default(autoincrement())
  tenantId          String    @map("tenant_id") @db.Uuid
  flowId            Int?      @map("flow_id")
  adminUserId       Int?      @map("admin_user_id")
  /// "manual" | "api" | "llm"
  source            String    @default("manual") @db.VarChar(30)
  originalJson      Json      @map("original_json")
  parsedNodes       Int       @default(0) @map("parsed_nodes")
  validationErrors  Json?     @map("validation_errors")
  /// "imported" | "validated" | "failed" | "published"
  status            String    @default("imported") @db.VarChar(20)
  createdAt         DateTime  @default(now()) @map("created_at")
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@map("waba_import_logs")
}
