// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id              String          @id @default(uuid()) @db.Uuid
  nombre          String          @db.VarChar(100)
  slug            String          @unique @db.VarChar(50)
  apiKey          String          @unique @db.VarChar(64) @map("api_key")
  activo          Boolean         @default(true)
  plan            String          @default("free") @db.VarChar(20)
  logoUrl         String?         @db.VarChar(500) @map("logo_url")
  createdAt       DateTime        @default(now()) @map("created_at")
  users           User[]
  solicitudes     Solicitud[]
  eventosFlujo    EventoFlujo[]
  agentes         Agente[]
  configuraciones Configuracion[]
  flows                Flow[]
  mensajes             Mensaje[]
  conversationContexts ConversationContext[]
  waSendQueue          WaSendQueue[]
  wabaRescueLogs       WabaRescueLog[]
  agendaEvents         AgendaEvent[]
  agendaEventLogs      AgendaEventLog[]
  eventLogs            EventLog[]
  deadLetterEntries    DeadLetterQueue[]
  flowSessions         FlowSession[]
  flowVersions         FlowVersion[]
  flowExecutions       FlowExecution[]
  integrations         Integration[]
  flowVariables        FlowVariable[]

  @@map("tenants")
}

model EventSchema {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  version   String   @db.VarChar(20)
  schema    Json
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, version])
  @@map("event_schemas")
}

model EventLog {
  id             Int       @id @default(autoincrement())
  tenantId       String    @map("tenant_id") @db.Uuid
  eventId        String    @unique @map("event_id") @db.VarChar(80)
  eventVersion   String    @default("1.0") @map("event_version") @db.VarChar(20)
  channel        String    @db.VarChar(40)
  source         String    @db.VarChar(60)
  eventType      String    @map("event_type") @db.VarChar(80)
  direction      String    @default("inbound") @db.VarChar(20)
  idempotencyKey String    @map("idempotency_key") @db.VarChar(191)
  status         String    @default("ingested") @db.VarChar(20)
  occurredAt     DateTime  @map("occurred_at")
  ingestedAt     DateTime  @default(now()) @map("ingested_at")
  processedAt    DateTime? @map("processed_at")
  payload        Json
  metadata       Json?
  rawEvent       Json?     @map("raw_event")
  lastError      String?   @map("last_error") @db.Text
  attempts       Int       @default(0)
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deadLetters    DeadLetterQueue[]

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, ingestedAt])
  @@index([tenantId, eventType, ingestedAt])
  @@map("event_logs")
}

model DeadLetterQueue {
  id          Int       @id @default(autoincrement())
  tenantId    String    @map("tenant_id") @db.Uuid
  eventLogId  Int?      @map("event_log_id")
  reason      String    @db.VarChar(255)
  error       Json?
  payload     Json?
  status      String    @default("pending") @db.VarChar(20)
  attempts    Int       @default(0)
  nextRetryAt DateTime? @map("next_retry_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eventLog    EventLog? @relation(fields: [eventLogId], references: [id], onDelete: SetNull)

  @@index([status, nextRetryAt])
  @@index([tenantId, createdAt])
  @@map("dead_letter_queue")
}

model User {
  id           Int           @id @default(autoincrement())
  tenantId     String        @map("tenant_id") @db.Uuid
  phone        String?       @db.VarChar(20)
  createdAt    DateTime      @default(now()) @map("created_at")
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  solicitudes         Solicitud[]
  eventosFlujo        EventoFlujo[]
  mensajes            Mensaje[]
  conversationContexts ConversationContext[]

  @@unique([tenantId, phone])
  @@map("users")
}

model Solicitud {
  id               Int      @id @default(autoincrement())
  tenantId         String   @map("tenant_id") @db.Uuid
  userId           Int?     @map("user_id")
  agenteId         Int?     @map("agente_id")
  nombre           String?  @db.VarChar(100)
  telefonoContacto String?  @db.VarChar(20)   @map("telefono_contacto")
  horario          String?  @db.VarChar(20)
  estado           String?  @db.VarChar(50)
  createdAt        DateTime @default(now()) @map("created_at")
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  user             User?    @relation(fields: [userId], references: [id])
  agente           Agente?  @relation(fields: [agenteId], references: [id])

  @@map("solicitudes")
}

model EventoFlujo {
  id        Int      @id @default(autoincrement())
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    Int?     @map("user_id")
  screen    String?  @db.VarChar(50)
  data      Json?
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@map("eventos_flujo")
}

model Agente {
  id          Int         @id @default(autoincrement())
  tenantId    String      @map("tenant_id") @db.Uuid
  nombre      String      @db.VarChar(100)
  email       String      @db.VarChar(150)
  estado      String      @default("activo") @db.VarChar(20)
  lastSeenAt  DateTime?   @map("last_seen_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  solicitudes Solicitud[]
  agendaAssignments AgendaEventAssignment[]

  @@map("agentes")
}

model Configuracion {
  id        Int      @id @default(autoincrement())
  tenantId  String   @map("tenant_id") @db.Uuid
  clave     String   @db.VarChar(100)
  valor     Json
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, clave])
  @@map("configuraciones")
}

// ── RBAC ──────────────────────────────────────────────────────────────────────

model AdminUser {
  id              Int            @id @default(autoincrement())
  tenantId        String?        @map("tenant_id") @db.Uuid
  email           String         @unique @db.VarChar(150)
  passwordHash    String         @map("password_hash") @db.VarChar(255)
  nombre          String         @db.VarChar(100)
  superAdmin      Boolean        @default(false) @map("super_admin")
  failedAttempts  Int            @default(0) @map("failed_attempts")
  lockedUntil     DateTime?      @map("locked_until")
  createdAt       DateTime       @default(now()) @map("created_at")
  roles           AdminUserRole[]
  auditLogs       AuditLog[]
  refreshTokens   RefreshToken[]
  wabaRescueLogs  WabaRescueLog[]
  agendaEventsCreated AgendaEvent[]       @relation("AgendaEventCreatedBy")
  agendaEventLogs     AgendaEventLog[]
  flowVersionsCreated FlowVersion[]       @relation("FlowVersionCreatedBy")

  @@map("admin_users")
}

model Role {
  id          Int            @id @default(autoincrement())
  tenantId    String?        @map("tenant_id") @db.Uuid
  nombre      String         @db.VarChar(100)
  createdAt   DateTime       @default(now()) @map("created_at")
  permisos    RolePermiso[]
  users       AdminUserRole[]

  @@map("roles")
}

model Permiso {
  id     Int           @id @default(autoincrement())
  clave  String        @unique @db.VarChar(100)
  roles  RolePermiso[]

  @@map("permisos")
}

model RolePermiso {
  roleId    Int    @map("role_id")
  permisoId Int    @map("permiso_id")
  role      Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permiso   Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@id([roleId, permisoId])
  @@map("role_permisos")
}

model AdminUserRole {
  adminUserId Int       @map("admin_user_id")
  roleId      Int       @map("role_id")
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([adminUserId, roleId])
  @@map("admin_user_roles")
}

// ── Auditoría ─────────────────────────────────────────────────────────────────

model RefreshToken {
  id          Int       @id @default(autoincrement())
  adminUserId Int       @map("admin_user_id")
  tokenHash   String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt   DateTime  @map("expires_at")
  revoked     Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@map("refresh_tokens")
}

model AuditLog {
  id          Int        @id @default(autoincrement())
  tenantId    String?    @map("tenant_id") @db.Uuid
  adminUserId Int?       @map("admin_user_id")
  accion      String     @db.VarChar(100)
  entidad     String     @db.VarChar(100)
  entidadId   String?    @map("entidad_id") @db.VarChar(100)
  ip          String?    @db.VarChar(45)
  userAgent   String?    @map("user_agent") @db.VarChar(500)
  metadata    Json?
  createdAt   DateTime   @default(now()) @map("created_at")
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id])

  @@index([tenantId])
  @@index([accion])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── Flujos dinámicos ──────────────────────────────────────────────────────────

model Flow {
  id           Int        @id @default(autoincrement())
  tenantId     String     @map("tenant_id") @db.Uuid
  nombre       String     @db.VarChar(100)
  version      Int        @default(1)
  activo       Boolean    @default(true)
  /// Snapshot del JSON Meta exportado (version 7.1) guardado en cada save
  metaJson     Json?      @map("meta_json")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  nodes        FlowNode[]
  edges        FlowEdge[]
  sessions     FlowSession[]
  agendaEvents AgendaEvent[]
  flowVersions FlowVersion[]
  executions   FlowExecution[]
  variables    FlowVariable[]

  @@map("flows")
}

model FlowSession {
  id                  Int      @id @default(autoincrement())
  tenantId            String   @map("tenant_id") @db.Uuid
  flowId              Int      @map("flow_id")
  sessionKey          String   @map("session_key") @db.VarChar(120)
  status              String   @default("active") @db.VarChar(20)
  currentScreenId     String?  @map("current_screen_id") @db.VarChar(120)
  stateJson           Json     @default("{}") @map("state_json")
  businessContextJson Json?    @map("business_context_json")
  auditEventsJson     Json     @default("[]") @map("audit_events_json")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flow                Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@unique([tenantId, flowId, sessionKey])
  @@index([tenantId, updatedAt])
  @@index([flowId, status])
  @@map("flow_sessions")
}

// ── Agenda ───────────────────────────────────────────────────────────────────

model AgendaEvent {
  id                     Int      @id @default(autoincrement())
  tenantId               String   @map("tenant_id") @db.Uuid
  createdByAdminUserId   Int?     @map("created_by_admin_user_id")
  flowId                 Int?     @map("flow_id")
  titulo                 String   @db.VarChar(160)
  descripcion            String?  @db.Text
  tipo                   String   @db.VarChar(30)
  color                  String   @default("#60A5FA") @db.VarChar(20)
  estado                 String   @default("pendiente") @db.VarChar(30)
  startAt                DateTime @map("start_at")
  endAt                  DateTime @map("end_at")
  reminderMinutes        Int?     @map("reminder_minutes")
  triggerWebhookOnStart  Boolean  @default(false) @map("trigger_webhook_on_start")
  webhookUrl             String?  @map("webhook_url") @db.VarChar(500)
  webhookMethod          String?  @map("webhook_method") @db.VarChar(10)
  webhookHeaders         Json?    @map("webhook_headers")
  webhookPayload         Json?    @map("webhook_payload")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator                AdminUser? @relation("AgendaEventCreatedBy", fields: [createdByAdminUserId], references: [id], onDelete: SetNull)
  flow                   Flow?    @relation(fields: [flowId], references: [id], onDelete: SetNull)
  assignments            AgendaEventAssignment[]
  logs                   AgendaEventLog[]

  @@index([tenantId, startAt])
  @@index([tenantId, estado, startAt])
  @@index([tenantId, tipo, startAt])
  @@map("agenda_events")
}

model AgendaEventAssignment {
  eventId   Int   @map("event_id")
  agenteId  Int   @map("agente_id")
  createdAt DateTime @default(now()) @map("created_at")
  event     AgendaEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  agente    Agente      @relation(fields: [agenteId], references: [id], onDelete: Cascade)

  @@id([eventId, agenteId])
  @@index([agenteId])
  @@map("agenda_event_assignments")
}

model AgendaEventLog {
  id            Int      @id @default(autoincrement())
  tenantId      String   @map("tenant_id") @db.Uuid
  eventId       Int      @map("event_id")
  adminUserId   Int?     @map("admin_user_id")
  accion        String   @db.VarChar(80)
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event         AgendaEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  adminUser     AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([eventId, createdAt])
  @@map("agenda_event_logs")
}

model FlowNode {
  id       Int      @id @default(autoincrement())
  flowId   Int      @map("flow_id")
  type     String   @db.VarChar(50)
  content  Json
  posX     Float    @default(0) @map("pos_x")
  posY     Float    @default(0) @map("pos_y")
  flow     Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  edgesOut FlowEdge[] @relation("SourceNode")
  edgesIn  FlowEdge[] @relation("TargetNode")

  @@map("flow_nodes")
}

model FlowEdge {
  id           Int      @id @default(autoincrement())
  flowId       Int      @map("flow_id")
  sourceNodeId Int      @map("source_node_id")
  targetNodeId Int      @map("target_node_id")
  condition    String?  @db.VarChar(255)
  flow         Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  sourceNode   FlowNode @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode   FlowNode @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@map("flow_edges")
}

// ── WhatsApp Business Cloud API ───────────────────────────────────────────────

model Mensaje {
  id        Int      @id @default(autoincrement())
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    Int?     @map("user_id")
  waMsgId   String?  @unique @map("wa_msg_id") @db.VarChar(100)
  /// "entrada" | "salida"
  direccion String   @db.VarChar(10)
  /// "text" | "interactive" | "image" | "audio" | "document" | "template"
  tipo      String   @db.VarChar(30)
  contenido Json
  leido     Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@index([tenantId, userId])
  @@index([tenantId, createdAt])
  @@map("mensajes")
}

// ── Chatbot state ─────────────────────────────────────────────────────────────

model ConversationContext {
  id               Int      @id @default(autoincrement())
  tenantId         String   @map("tenant_id") @db.Uuid
  userId           Int      @map("user_id")
  currentNodeId    Int?     @map("current_node_id")
  /// For JSONB-based flows: string node ref (e.g. "node_1")
  currentNodeRef   String?  @map("current_node_ref") @db.VarChar(120)
  /// Link to active FlowExecution record (enterprise engine)
  flowExecutionId  Int?     @map("flow_execution_id")
  engine           String   @default("flow_engine") @db.VarChar(30)
  variables        Json     @default("{}")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@map("conversation_contexts")
}

model WaSendQueue {
  id          Int      @id @default(autoincrement())
  tenantId    String   @map("tenant_id") @db.Uuid
  phone       String   @db.VarChar(20)
  payload     Json
  status      String   @default("pending") @db.VarChar(20)
  attempts    Int      @default(0)
  lastError   String?  @map("last_error") @db.Text
  scheduledAt DateTime @default(now()) @map("scheduled_at")
  createdAt   DateTime @default(now()) @map("created_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@map("wa_send_queue")
}

// ── LLM / WABA Rescue ─────────────────────────────────────────────────────────

model WabaRescueLog {
  id              Int        @id @default(autoincrement())
  tenantId        String     @map("tenant_id") @db.Uuid
  adminUserId     Int?       @map("admin_user_id")
  originalJson    Json       @map("original_json")
  wabaError       Json       @map("waba_error")
  diagnosis       Json?
  fixedJson       Json?      @map("fixed_json")
  changes         Json?
  confidenceScore Int?       @map("confidence_score")
  /// "pending" | "fixed" | "failed" | "manual_review"
  status          String     @default("pending") @db.VarChar(20)
  llmUsed         Boolean    @default(false) @map("llm_used")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  adminUser       AdminUser? @relation(fields: [adminUserId], references: [id])

  @@index([tenantId, createdAt])
  @@map("waba_rescue_logs")
}

// ── Enterprise: Versionado, Ejecución, Integraciones ─────────────────────────

/// Snapshot inmutable de la definición de un flujo en un momento dado.
/// La columna `definition` es JSONB y contiene la estructura completa de nodos,
/// variables e integraciones — el motor de ejecución trabaja SOLO con este JSON.
model FlowVersion {
  id                   Int       @id @default(autoincrement())
  tenantId             String    @map("tenant_id") @db.Uuid
  flowId               Int       @map("flow_id")
  versionNumber        Int       @map("version_number")
  /// Full JSONB: { entry_point, nodes:[{id,type,config,next,integrationRef?}], variables:{}, metadata:{} }
  definition           Json
  changelog            String?   @db.Text
  published            Boolean   @default(false)
  publishedAt          DateTime? @map("published_at")
  createdByAdminUserId Int?      @map("created_by_admin_user_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flow                 Flow      @relation(fields: [flowId], references: [id], onDelete: Cascade)
  creator              AdminUser? @relation("FlowVersionCreatedBy", fields: [createdByAdminUserId], references: [id], onDelete: SetNull)
  executions           FlowExecution[]

  @@unique([flowId, versionNumber])
  @@index([tenantId, flowId, published])
  @@index([tenantId, createdAt])
  @@map("flow_versions")
}

/// Registro de ejecución de un flujo por usuario/sesión.
/// Reemplaza ConversationContext para flujos versionados (JSONB-based).
/// `variables` y `context` son JSONB para máxima flexibilidad.
model FlowExecution {
  id              Int       @id @default(autoincrement())
  tenantId        String    @map("tenant_id") @db.Uuid
  flowId          Int       @map("flow_id")
  flowVersionId   Int?      @map("flow_version_id")
  /// Identificador de sesión: phone number, socket id, etc.
  sessionKey      String    @map("session_key") @db.VarChar(120)
  /// "active" | "completed" | "error" | "abandoned"
  status          String    @default("active") @db.VarChar(20)
  /// ID del nodo actual dentro del JSON (ej: "node_1")
  currentNodeRef  String?   @map("current_node_ref") @db.VarChar(120)
  /// Variables de sesión dinámicas (capturadas durante el flujo)
  variables       Json      @default("{}")
  /// Contexto extra: intent, metadata de canal, etc.
  context         Json      @default("{}")
  errorCount      Int       @default(0) @map("error_count")
  startedAt       DateTime  @default(now()) @map("started_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  completedAt     DateTime? @map("completed_at")
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flow            Flow      @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowVersion     FlowVersion? @relation(fields: [flowVersionId], references: [id], onDelete: SetNull)
  logs            ExecutionLog[]

  @@unique([tenantId, flowId, sessionKey])
  @@index([tenantId, status, updatedAt])
  @@index([flowId, status])
  @@index([tenantId, updatedAt])
  @@map("flow_executions")
}

/// Log atómico por nodo ejecutado dentro de un FlowExecution.
/// Permite auditoría completa paso a paso y debugging de flujos.
model ExecutionLog {
  id           Int      @id @default(autoincrement())
  executionId  Int      @map("execution_id")
  tenantId     String   @map("tenant_id") @db.Uuid
  /// Referencia al nodo en el JSON (ej: "node_3")
  nodeRef      String   @map("node_ref") @db.VarChar(120)
  nodeType     String   @map("node_type") @db.VarChar(50)
  /// Input recibido en este paso
  input        Json?
  /// Output generado (texto, respuesta de API, etc.)
  output       Json?
  durationMs   Int?     @map("duration_ms")
  /// "ok" | "error" | "skipped"
  status       String   @default("ok") @db.VarChar(20)
  errorMessage String?  @map("error_message") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  execution    FlowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, createdAt])
  @@index([tenantId, createdAt])
  @@map("execution_logs")
}

/// Configuración de integraciones dinámicas (webhooks, REST APIs, OAuth2).
/// El motor de ejecución resuelve nodos tipo "action" contra esta tabla —
/// sin hardcode de endpoints, headers ni lógica de autenticación.
model Integration {
  id        Int      @id @default(autoincrement())
  tenantId  String   @map("tenant_id") @db.Uuid
  nombre    String   @db.VarChar(100)
  /// "webhook" | "rest_api" | "oauth2" | "apikey"
  tipo      String   @db.VarChar(30)
  /// JSONB: { endpoint, method, headers, auth:{type,key?,token?,oauth_config?},
  ///          body_mapping:{}, response_mapping:{}, timeout_ms, retry_count }
  config    Json
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, nombre])
  @@index([tenantId, activo])
  @@map("integrations")
}

/// Definición de variables de flujo: globales (flowId=null) o por flujo.
/// Permite al motor resolver plantillas {{variable}} sin hardcode.
model FlowVariable {
  id           Int      @id @default(autoincrement())
  tenantId     String   @map("tenant_id") @db.Uuid
  /// null = variable global del tenant
  flowId       Int?     @map("flow_id")
  nombre       String   @db.VarChar(100)
  /// "string" | "number" | "boolean" | "object" | "array"
  tipo         String   @default("string") @db.VarChar(20)
  /// Valor por defecto serializado como JSONB
  valorDefault Json?    @map("valor_default")
  descripcion  String?  @db.VarChar(255)
  /// "global" | "flow" | "session"
  scope        String   @default("flow") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flow         Flow?    @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@unique([tenantId, flowId, nombre])
  @@index([tenantId, scope])
  @@map("flow_variables")
}
