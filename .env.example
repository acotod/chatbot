DATABASE_URL="postgresql://user:password@localhost:5432/chatbot"
PORT=3000
NODE_ENV=development

# Comma-separated list of allowed browser origins for CORS
# Example: http://localhost:3001,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# Admin API key for /admin/* routes (generate with: openssl rand -hex 32)
ADMIN_API_KEY=

# JWT secret
JWT_SECRET=

# Redis connection (optional — enables rate limiting via Redis)
REDIS_URL=redis://localhost:6379

# Rate limit: max requests per tenant per minute (default: 100)
RATE_LIMIT_PER_TENANT=100

# ── WhatsApp Business Cloud API ───────────────────────────────────────────────
# Token used by Meta to verify webhook endpoints (GET /webhook and GET /whatsapp)
# Generate any random string: openssl rand -hex 24
WA_VERIFY_TOKEN=

# Per-tenant credentials are stored in the DB (configuraciones table):
#   clave: "wa_credentials"
#   valor: { "phoneNumberId": "...", "accessToken": "..." }
# phoneNumberId: found in Meta Business Manager → WhatsApp → Phone Numbers
# accessToken:   permanent system-user token with whatsapp_business_messaging scope

