DATABASE_URL="postgresql://user:password@localhost:5432/chatbot"
PORT=3000
NODE_ENV=development

# Admin API key for /admin/* routes (generate with: openssl rand -hex 32)
ADMIN_API_KEY=

# Redis connection (optional — enables rate limiting via Redis)
REDIS_URL=redis://localhost:6379

# Rate limit: max requests per tenant per minute (default: 100)
RATE_LIMIT_PER_TENANT=100

